# ─── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_REASONING=llama-3.3-70b-versatile

# ─── Databases ────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333            # or https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=                            # leave empty for local Docker
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB_NAME=defectsense
REDIS_URL=redis://localhost:6379           # rediss:// for Upstash TLS

# ─── ML Models ────────────────────────────────────────────────────────────────
ML_MODELS_PATH=ml/models
ANOMALY_THRESHOLD_MULTIPLIER=3.0
SEQUENCE_LENGTH=30

# ─── Agent Config ─────────────────────────────────────────────────────────────
AMEM_ENABLED=true
LETTA_ENABLED=false
LETTA_BASE_URL=http://localhost:8283
HUMAN_APPROVAL_TIMEOUT_MINUTES=15
AUTO_APPROVE_CONFIDENCE_THRESHOLD=0.95

# ─── Observability ────────────────────────────────────────────────────────────
# Set to true only if you have an active LangSmith account with quota remaining
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=defectsense
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db

# ─── App ──────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
LOG_LEVEL=INFO
ENVIRONMENT=development

# ─── PostgreSQL (Supabase) ────────────────────────────────────────────────────
# Session pooler URL — always use this format
# Get from: supabase.com → Connect button
POSTGRES_URL=postgresql://postgres.yourprojectid:password@aws-0-region.pooler.supabase.com:6543/postgres

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
# Connection string from Azure Portal → Storage Account → Access Keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# Container that holds versioned ML model artefacts (must already exist)
AZURE_STORAGE_CONTAINER=defectsense-models

# ─── Frontend ─────────────────────────────────────────────────────────────────
API_BASE=http://localhost:8080             # Gradio -> FastAPI backend URL
